<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Video Manager</title>

<style>
* {
    box-sizing: border-box;
    font-family: "Segoe UI", Arial, sans-serif;
}

html {
    scroll-behavior: smooth;
}

body {
    margin: 0;
    padding: 20px;
    background: linear-gradient(135deg,#0f2027,#203a43,#2c5364);
    color: #fff;
}

/* Headings */
h1, h2, h3 {
    text-align: center;
    margin-bottom: 15px;
}

/* Glass card */
.card {
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(12px);
    border-radius: 14px;
    padding: 20px;
    max-width: 450px;
    margin: 20px auto;
    box-shadow: 0 15px 40px rgba(0,0,0,0.4);
}

/* Inputs */
input[type="text"], input[type="file"] {
    width: 100%;
    padding: 12px;
    margin-bottom: 12px;
    border-radius: 8px;
    border: none;
    outline: none;
    background: rgba(0,0,0,0.4);
    color: #fff;
    font-size: 14px;
}

input::placeholder {
    color: #aaa;
}

/* Buttons */
button {
    padding: 10px 16px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 14px;
    margin-top: 5px;
    transition: 0.3s ease;
}

.connect-btn {
    width: 100%;
    background: linear-gradient(135deg,#00c6ff,#0072ff);
    color: #fff;
}

.upload-btn {
    width: 100%;
    background: linear-gradient(135deg,#28a745,#1e7e34);
    color: #fff;
}

.copy-btn {
    background: #17a2b8;
    color: #fff;
}

.delete-btn {
    background: #dc3545;
    color: #fff;
}

button:hover {
    opacity: 0.85;
    transform: translateY(-2px);
}

/* Video Container */
.video-container {
    max-width: 800px;
    margin: auto;
}

.video-card {
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(10px);
    padding: 15px;
    border-radius: 12px;
    margin-bottom: 20px;
    box-shadow: 0 8px 25px rgba(0,0,0,0.35);
    text-align: center;
}

video {
    width: 100%;
    border-radius: 10px;
    margin-bottom: 10px;
}

.url {
    font-size: 12px;
    color: #ccc;
    word-break: break-all;
    margin-top: 8px;
    display: block;
}

.url a {
    color: #00c6ff;
    text-decoration: underline;
}
.url a:hover {
    color: #66d9ff;
}
</style>

<script>
function copyUrl(url){
    navigator.clipboard.writeText(url);
    alert("✅ URL Copied");
}
</script>

</head>

<body>

<!-- MongoDB Connect -->
<div class="card">
<h2>MongoDB Connect</h2>
<form action="/connect" method="POST">
<input type="text" name="mongo" placeholder="MongoDB URI">
<button type="submit" class="connect-btn">Connect</button>
</form>

<h3>Uploads Folder Size: <%= folderSize %> MB</h3>
<h3>Total Files: <%= totalFiles %></h3>
</div>

<!-- Upload Video -->
<div class="card">
<h1>Upload Video</h1>
<form action="/upload" method="POST" enctype="multipart/form-data">
<input type="file" name="video" required>
<button class="upload-btn">Upload</button>
</form>
</div>
<div class="card">
<h2>Upload From URL</h2>
<form action="/upload-url" method="POST">
<input type="text" name="videoUrl" placeholder="Paste video URL here" required>
<button class="upload-btn">Upload from URL</button>
</form>
</div>

<!-- Video List -->
<h2>📂 Videos</h2>
<div class="video-container">
<% videos.forEach(video=>{ %>
<div class="video-card">


<!-- Copy & Delete -->
<button class="copy-btn" onclick="copyUrl('<%= video.url %>')">Copy URL</button>
<form action="/delete/<%= video._id %>" method="POST" style="display:inline">
<button class="delete-btn">Delete</button>
</form>


<!-- URL -->
<p class="url"><a href="<%= video.url %>" target="_blank"><%= video.url %></a></p>

</div>
<% }) %>
</div>



</body>
</html>